# Claude API (Vercel Functions)
ANTHROPIC_API_KEY=

# Expo client variables
EXPO_PUBLIC_API_URL=https://your-vercel-url.vercel.app

# RevenueCat
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxxx

# AdMob (replace with real IDs from AdMob console)
EXPO_PUBLIC_ADMOB_REWARDED_IOS=ca-app-pub-xxxxxxxxxxxxx/xxxxxxxxxxxxx
EXPO_PUBLIC_ADMOB_REWARDED_ANDROID=ca-app-pub-xxxxxxxxxxxxx/xxxxxxxxxxxxx
EXPO_PUBLIC_ADMOB_BANNER_IOS=ca-app-pub-xxxxxxxxxxxxx/xxxxxxxxxxxxx
EXPO_PUBLIC_ADMOB_BANNER_ANDROID=ca-app-pub-xxxxxxxxxxxxx/xxxxxxxxxxxxx

# Fastlane / App Store Connect
APPLE_ID=your@email.com
ITC_TEAM_ID=
DEV_TEAM_ID=
APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_API_ISSUER_ID=
APP_STORE_CONNECT_API_KEY_PATH=./fastlane/AuthKey_XXXXXXXXXX.p8

# Fastlane / Google Play
GOOGLE_PLAY_JSON_KEY_FILE=./fastlane/google-play-key.json

# Build output paths (set before running fastlane lanes)
IPA_PATH=./build/koreantalk.ipa
AAB_PATH=./build/koreantalk.aab
